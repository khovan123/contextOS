{
  "name": "ctx",
  "version": "0.1.0",
  "description": "ContextOS injects task-relevant AGENTS.md context into Codex through plugin hooks.",
  "type": "module",
  "bin": {
    "ctx": "./bin/ctx.js"
  },
  "files": [
    "bin/",
    "plugins/",
    ".agents/",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "test": "vitest run",
    "build": "node bin/ctx.js --version",
    "validate:plugin": "node test/validate-plugin.js",
    "test:mcp": "node test/mcp-protocol-smoke.js"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "vitest": "^3.2.4"
  },
  "keywords": [
    "codex",
    "plugin",
    "agents",
    "context",
    "hooks"
  ],
  "author": {
    "name": "ContextOS"
  },
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@xenova/transformers": "^2.17.2",
    "sql.js": "^1.14.1",
    "zod": "^4.4.3"
  }
}
